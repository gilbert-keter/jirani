    classDef default fill:#fff,stroke:#000,stroke-width:2px,color:#000
    classDef decision fill:#fff,stroke:#000,stroke-width:2px,color:#000
    classDef database fill:#fff,stroke:#000,stroke-width:2px,color:#000
    classDef process fill:#fff,stroke:#000,stroke-width:2px,color:#000
    classDef endpoint fill:#fff,stroke:#000,stroke-width:3px,color:#000
    
    class Start,Complete endpoint
    class Role,TokenCheck,TokSuccess,SlotAvail,ConfirmBook,PaySelect,PayResult,ProvResponse,StartService,CustomerAction,CustomerReview,AICheck,AdminCheck,BadgeCheck,ProviderReviewOpt,WithdrawDecision,ValidateAmount,SelectMethod,ConfirmWithdraw,TransferResult,NeedMoreInfo,AdminDecision,RefundGateway,CheckDiscrepancies,ApplyFilter decision
    class TokCredit,PublishSvc,IndexES,ESQuery,CheckSlot,PlatformAcc,ProviderPending,PlatformFee,CreateEscrow,RecordTxn,ConfirmStatus,InProgress,CompletedStatus,ReleaseEscrow,UpdateBalance,RecordRelease,UpdateProfile,UpdateStats,CustomerRep,VerifyDetails,CreateWithdrawal,DeductFromBalance,RecordFeeRevenue,UpdateProviderDB,WithdrawSuccess,WithdrawFailed,CreateDispute,FreezeEscrow,AdminQueue,ReleaseForRefund,RefundStatus,ReleaseToProvider,MarkAsCompleted,DisputeResolved,IdentifyOriginalMethod,RecordRefund,UpdateBookingDB,UpdateEscrowDB,PostgreSQL,Redis,Elasticsearch,MongoDB database